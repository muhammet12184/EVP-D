# Environment
ENVIRONMENT=development

# Database
DATABASE_URL=mongodb://localhost:27017/supermobility
REDIS_URL=redis://localhost:6379

# AWS
AWS_REGION=us-east-1
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Mapbox
MAPBOX_TOKEN=your-mapbox-access-token

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Blockchain
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your-project-id

# API URLs
API_BASE_URL=http://localhost:8080
AI_SERVICES_URL=http://localhost:8000

# Mobile App
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com
