# Güvenlik Yapılandırması
# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin

# JWT Secret Key - Güçlü bir rastgele string kullanın
SECRET_KEY=your-super-secret-key-change-this-in-production

# Encryption Key - Fernet anahtarı (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-encryption-key-change-this

# Allowed Origins - CORS için izin verilen domain'ler (virgülle ayırın)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Trusted Hosts - İzin verilen host'lar (virgülle ayırın)
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database URL (gelecekte kullanım için)
DATABASE_URL=sqlite:///./ev_data.db

# Log Level
LOG_LEVEL=INFO

# Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
