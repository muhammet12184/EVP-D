<?xml version="1.0" encoding="utf-8"?>
<!-- 
    ÖRNEK LAYOUT - Butonların doğru çalışması için
    Bu dosyayı res/layout/activity_main.xml olarak kaydedin
-->
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:clickable="false"
    android:focusable="false">

    <!-- LOGO / BAŞLIK -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OBD-II Bağlantı"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- DURUM GÖSTERGE -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bağlantı bekleniyor..."
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <!-- TARA BUTONU -->
    <Button
        android:id="@+id/scanButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🔍 Cihaz Tara"
        android:textSize="16sp"
        android:enabled="true"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#2196F3" />

    <!-- BAĞLAN BUTONU -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🔗 Bağlan"
        android:textSize="16sp"
        android:enabled="true"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#4CAF50" />

    <!-- BAĞLANTIYI KES BUTONU -->
    <Button
        android:id="@+id/disconnectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="❌ Bağlantıyı Kes"
        android:textSize="16sp"
        android:enabled="true"
        android:clickable="true"
        android:focusable="true"
        android:backgroundTint="#F44336" />

    <!-- 
    ⚠️ ÖNEMLİ NOTLAR:
    
    1. Tüm butonlarda şunlar OLMALI:
       - android:enabled="true"
       - android:clickable="true"
       - android:focusable="true"
    
    2. Parent layout'ta şunlar OLMAMALI:
       - android:clickable="true" (tıklamayı engeller)
    
    3. Butonların üstünde başka view OLMAMALI
    
    4. ConstraintLayout kullanıyorsanız, butonların 
       constraint'leri doğru tanımlanmış olmalı
    -->

</LinearLayout>
